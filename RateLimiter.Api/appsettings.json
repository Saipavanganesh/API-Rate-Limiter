{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "RequestsPerWindow": 10,
    "WindowSizeSeconds": 60,
    "Strategy":  "PerIp",
    "Redis": {
      "ConnectionString": "localhost:6379"
    }
  }
 }
